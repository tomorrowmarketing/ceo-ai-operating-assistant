# Data source: mock only unless external integrations are intentionally restored.
DATA_SOURCE=mock

# Daily report delivery is disabled by default.
# Do not add Gmail, Telegram, or cron tokens unless this feature is intentionally restored.
ENABLE_DAILY_REPORT_DELIVERY=false

# External Notion and AI integrations are disabled by default.
# Do not add Notion or Anthropic tokens unless these features are intentionally restored.
ENABLE_NOTION_INTEGRATION=false
ENABLE_AI_SUMMARY=false
