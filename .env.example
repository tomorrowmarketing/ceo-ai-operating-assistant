# Data source: mock (default) | notion
DATA_SOURCE=mock

# Daily report delivery is disabled by default.
# Do not add Gmail, Telegram, or cron tokens unless this feature is intentionally restored.
ENABLE_DAILY_REPORT_DELIVERY=false

# Notion integration. Required only when DATA_SOURCE=notion.
NOTION_TOKEN=
NOTION_DB_ADVERTISERS=
NOTION_DB_STAFF=
NOTION_DB_TASKS=
NOTION_DB_COMMUNICATIONS=
NOTION_DB_CALENDAR=
NOTION_DB_FINANCE=
NOTION_DB_CONTRACTS=

# AI summary. Optional.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
