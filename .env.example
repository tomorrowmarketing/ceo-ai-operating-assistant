# 데이터 소스 선택: mock (기본) | notion
DATA_SOURCE=mock

# ───────── Notion 연동 (DATA_SOURCE=notion 일 때만 필요) ─────────
# Notion 내부 통합(Integration) 토큰 (서버 전용, 절대 클라이언트 노출 금지)
NOTION_TOKEN=

# 각 데이터베이스 ID (Notion DB 링크의 32자리 식별자)
NOTION_DB_ADVERTISERS=
NOTION_DB_STAFF=
NOTION_DB_TASKS=
NOTION_DB_COMMUNICATIONS=
NOTION_DB_CALENDAR=
NOTION_DB_FINANCE=
NOTION_DB_CONTRACTS=

# ───────── 일일 보고서 자동 발송 ─────────
# Gmail SMTP (앱 비밀번호 — 2단계 인증 후 발급)
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_TO=          # 받을 주소 (비우면 GMAIL_USER 본인에게)

# Telegram 봇 (@BotFather 로 생성)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=   # npm run telegram:chatid 로 확인

# Vercel Cron 보호용 (배포 시 Vercel 환경변수에 임의 문자열로 설정)
CRON_SECRET=
