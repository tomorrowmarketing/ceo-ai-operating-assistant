# 데이터 소스 선택: mock (기본) | notion
DATA_SOURCE=mock

# ───────── Notion 연동 (DATA_SOURCE=notion 일 때만 필요) ─────────
# Notion 내부 통합(Integration) 토큰 (서버 전용, 절대 클라이언트 노출 금지)
NOTION_TOKEN=

# 각 데이터베이스 ID (Notion DB 링크의 32자리 식별자)
NOTION_DB_ADVERTISERS=
NOTION_DB_STAFF=
NOTION_DB_TASKS=
NOTION_DB_COMMUNICATIONS=
NOTION_DB_CALENDAR=
NOTION_DB_FINANCE=
NOTION_DB_CONTRACTS=
